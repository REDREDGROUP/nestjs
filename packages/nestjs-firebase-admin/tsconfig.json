{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": false
  },
  "include": ["libs"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
